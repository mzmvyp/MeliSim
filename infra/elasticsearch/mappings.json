{
  "settings": {
    "number_of_shards": 1,
    "number_of_replicas": 0,
    "analysis": {
      "analyzer": {
        "melisim_text": {
          "type": "custom",
          "tokenizer": "standard",
          "filter": ["lowercase", "asciifolding"]
        }
      }
    }
  },
  "mappings": {
    "properties": {
      "id":          { "type": "long" },
      "seller_id":   { "type": "long" },
      "title":       { "type": "text", "analyzer": "melisim_text" },
      "description": { "type": "text", "analyzer": "melisim_text" },
      "category":    { "type": "keyword" },
      "price":       { "type": "double" },
      "stock":       { "type": "integer" },
      "created_at":  { "type": "date" }
    }
  }
}
